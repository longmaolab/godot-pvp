; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="DADABOOM"
config/description="DADABOOM — server-authoritative multiplayer arena shooter built in Godot 4.6 (lag-compensated netcode)."
run/main_scene="res://client/scenes/main_menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

NetProtocol="*res://shared/scripts/network/net_protocol.gd"
NetRpc="*res://shared/scripts/network/net_rpc.gd"
RoomManager="*res://server/scripts/room_manager.gd"
Database="*res://server/scripts/database.gd"
ProfileService="*res://server/scripts/profile_service.gd"
ReplayRecorder="*res://server/scripts/replay_recorder.gd"
InputSetup="*res://client/scripts/input/input_setup.gd"
HeadlessMain="*res://server/headless_main.gd"
ProcAudio="*res://client/scripts/audio/proc_audio.gd"
StatsStore="*res://client/scripts/persistence/stats_store.gd"
Settings="*res://client/scripts/persistence/settings.gd"
ServerDiscovery="*res://client/scripts/persistence/server_discovery.gd"

[gui]

theme/custom="res://assets/themes/pvp_theme.tres"

[display]

window/size/viewport_width=1280
window/size/viewport_height=880
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[physics]

3d/physics_engine="JoltPhysics3D"
3d/default_gravity=28.0
common/physics_interpolation=true

[rendering]

renderer/rendering_method.web="mobile"
textures/vram_compression/import_etc2_astc=true
