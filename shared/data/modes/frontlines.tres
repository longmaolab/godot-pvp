team_count = 2
default_bots_per_side = 3
rounds_to_win = 1
round_seconds = 0
kill_goal = 0
lives_per_player = -1
credits_per_kill = 5
credits_per_win = 90
credits_per_loss = 25
credit_cap_per_match = 300
rule_script = ExtResource("2")
