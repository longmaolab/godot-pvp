[ext_resource type="Script" path="res://shared/scripts/player_controller.gd" id="1_player"]

[sub_resource type="CapsuleShape3D" id="cap_body"]
height = 1.8
radius = 0.35

[sub_resource type="SphereShape3D" id="sph_head"]
; 0.32: combined with per-skin SKIN_SCALES in player_controller.gd, this
; covers every Kenney character's head mesh (neck at world Y≈1.65, head
; center near sphere center Y=1.9) plus a forgiveness margin for kids and
; long-range aim. Earlier 0.22 / 0.28 values were sized against the
; procedural box-head only, which was always at the same Y as the sphere —
; but the GLB skins were rendered 1.85× scale (head at world Y≈3.4–4.9),
; sitting entirely above the hitbox. See tests/measure_hitbox.gd.
radius = 0.32

[sub_resource type="CapsuleShape3D" id="cap_torso"]
; Was height 1.2 radius 0.32, offset +0.1 → covered only y=0.4~1.6 after the
; player settled (root y=0.9). That left the LEGS (y=0.2~0.9) and the upper
; TORSO (y=1.6~1.775) completely unhittable, with an additional 0.08m dead
; zone between body-top and head-bottom. Players reported "完全在人身上还是
; missed" — the visible model was much bigger than the hitbox. New dims match
; the CharacterBody3D collision capsule so the hittable volume is the same
; thing the player physically occupies.
height = 1.8
radius = 0.5

