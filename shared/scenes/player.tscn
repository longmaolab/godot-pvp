[node name="BodyHitbox" type="Area3D" parent="."]
; Offset 0 (was 0.1) — with the enlarged capsule (1.8 tall, 0.4 wide), this
; sits exactly on the same volume as BodyCollision, covering feet to neck.
; Head sphere (radius 0.28 at +1.0) overlaps the upper third of this capsule;
; intersect_ray returns the first collider along the ray so headshots still
; register correctly when aiming at the actual head height.
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0, 0)
collision_layer = 4
collision_mask = 0
monitoring = false
monitorable = true

