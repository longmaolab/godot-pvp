[node name="ModelHolder" type="Node3D" parent="Visuals"]
; CharacterBody3D capsule center sits at root.Y=0.9 after gravity settles
; (capsule height 1.8 → feet at Y=0). Kenney GLB origin is at the model's
; feet, so without this offset the rendered character floats 0.9m above the
; ground. -0.9 puts GLB feet on the floor. Visuals-only — does NOT move the
; physics collider or hitboxes.
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, -0.9, 0)

